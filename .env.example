# ============================
# Backend (apps/api)
# ============================
PORT=3001

# Neon PostgreSQL - Lấy từ https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google Gemini API - Lấy từ https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# OpenWeatherMap API - Lấy từ https://openweathermap.org/api (free tier)
OPENWEATHER_API_KEY=your_openweather_api_key

# JWT Authentication
JWT_SECRET=change-me-to-a-random-string

# Admin credentials (hardcoded cho demo)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ============================
# Frontend (apps/web)
# ============================
VITE_API_URL=http://localhost:3001
